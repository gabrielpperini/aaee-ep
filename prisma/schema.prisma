// App de Gestão da Delegação e Torcida — EP Engenharia UFRGS
// Schema cobrindo o MVP 1 (cadastros + agenda) com gancho para MVP 2 (operação).
// Veja ROADMAP.md para o detalhamento das fases.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum Role {
  USER
  DIRECTOR
  ADMIN
}

enum EventStatus {
  CONFIRMED // confirmado (padrão)
  CANCELLED // cancelado
  POSTPONED // adiado
  // "Em andamento" e "Finalizado" são derivados de startTime/endTime vs now.
  // "Possível" é derivado de isConditional = true.
}

enum EventPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum EventPhase {
  GROUP        // fase de grupos / classificatória
  ROUND_OF_16
  QUARTER
  SEMI
  FINAL
  THIRD_PLACE
  HEAT         // bateria
  ELIMINATORY  // eliminatória
  OTHER
}

enum ModalityCategory {
  SPORT       // esporte
  CULTURAL    // cultural
  CHEERING    // atividade de torcida
  LOGISTICS   // deslocamento / logística
  GENERAL     // evento geral da delegação
}

/// Cursos da Escola de Engenharia da UFRGS.
enum Course {
  CIVIL
  ELETRICA
  MECANICA
  COMPUTACAO
  CONTROLE_AUTOMACAO
  MATERIAIS
  CARTOGRAFICA
  ENERGIA
  METALURGICA
  QUIMICA
  PRODUCAO
  AMBIENTAL
  FISICA
}

/// Papel da pessoa numa alocação de torcida em um evento.
enum AssignmentRole {
  SUPPORTER      // torcedor
  CAPTAIN        // capitão da torcida
  MATERIAL_LEAD  // responsável pelo material
  SUPPORT        // apoio (logística, água, etc.)
}

// ============================================================
// Modelos
// ============================================================

/// Conta de login. Mapeia 1:1 com auth.users do Supabase via `authUserId`.
model User {
  id         String   @id @default(cuid())
  authUserId String?  @unique // uuid do Supabase auth.users
  email      String?  @unique
  phone      String?
  role       Role     @default(USER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  person Person?

  @@index([authUserId])
}

/// Pessoa da delegação. Pode ou não estar vinculada a um User (login).
/// Permite cadastrar antes da pessoa criar conta.
model Person {
  id          String   @id @default(cuid())
  userId      String?  @unique
  name        String
  nickname    String?
  /// Sempre normalizado (lowercase + trim) nas ações. Unique pra
  /// garantir auto-linking determinístico com User.
  email       String?  @unique
  phone       String?
  isAthlete   Boolean  @default(false)
  isSupporter Boolean  @default(true)
  isDirector  Boolean  @default(false)
  isSupport   Boolean  @default(false) // membro de apoio
  course      Course?
  semester    Int?     // 1..10
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  athleteIn       EventAthlete[]
  modalityAthlete ModalityAthlete[]
  assignments     Assignment[]
  checkIns        CheckIn[]

  @@index([name])
  @@index([email])
}

/// Modalidade esportiva ou tipo de evento.
model Modality {
  id        String           @id @default(cuid())
  name      String           @unique
  category  ModalityCategory @default(SPORT)
  priority  EventPriority    @default(NORMAL)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  events    Event[]
  athletes  ModalityAthlete[]
}

/// Vinculação atleta <-> modalidade (uma pessoa pode competir em várias).
model ModalityAthlete {
  modalityId String
  personId   String

  modality Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)
  person   Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([modalityId, personId])
}

/// Configuração da edição atual do EP. Singleton (sempre id="current").
/// As datas mapeiam os "days" usados em Event:
///  -1 = embarque / ida (ônibus pra cidade do EP)
///   0 = véspera / chegada
///   1, 2, 3 = dias principais de competição
///   4 = volta / desembarque
model EpEdition {
  id          String   @id @default("current")
  name        String?  // ex: "EP 2026 — Pelotas"
  dayMinus1   DateTime?
  day0        DateTime?
  day1        DateTime?
  day2        DateTime?
  day3        DateTime?
  day4        DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Local onde acontecem os eventos.
model Location {
  id          String   @id @default(cuid())
  name        String
  address     String?
  description String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events Event[]
}

/// Evento: jogo, luta, prova, bateria, atividade da torcida etc.
/// Horários armazenados como DateTime UTC; "day" derivado é redundante mas útil.
model Event {
  id                     String        @id @default(cuid())
  modalityId             String
  title                  String
  description            String?
  day                    Int           // -1 (chegada), 0 (véspera), 1, 2, 3 (dias principais) ou 4 (volta)
  startTime              DateTime
  endTime                DateTime
  locationId             String?
  opponent               String?
  phase                  EventPhase    @default(OTHER)
  priority               EventPriority @default(NORMAL)
  status                 EventStatus   @default(CONFIRMED)
  isConditional          Boolean       @default(false)
  desiredSupportersCount Int           @default(0)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  modality    Modality       @relation(fields: [modalityId], references: [id], onDelete: Restrict)
  // Restrict (não SetNull): deletar Location com eventos é geralmente engano
  // — força o admin a reatribuir o evento antes ou cancelá-lo.
  location    Location?      @relation(fields: [locationId], references: [id], onDelete: Restrict)
  athletes    EventAthlete[]
  assignments Assignment[]
  checkIns    CheckIn[]

  @@index([day, startTime])
  @@index([modalityId])
  @@index([status])
}

/// Atletas envolvidos em um evento específico (ex: o time daquela partida).
model EventAthlete {
  eventId  String
  personId String

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([eventId, personId])
}

// ============================================================
// MVP 2 — Operação da torcida
// ============================================================
//
// Regra: toda pessoa da delegação é disponível por padrão.
// Indisponibilidade é implícita — competindo no evento ou já alocada em
// outro evento que sobrepõe no horário.

/// Alocação de uma pessoa a um evento como torcida/apoio/capitão.
model Assignment {
  eventId   String
  personId  String
  role      AssignmentRole @default(SUPPORTER)
  isCaptain Boolean        @default(false)
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([eventId, personId])
  @@index([personId])
  @@index([eventId, isCaptain])
}

/// Registro de presença ("estou aqui") de uma pessoa em um evento.
/// PK composta evita check-in duplicado para o mesmo evento.
model CheckIn {
  eventId   String
  personId  String
  checkedAt DateTime @default(now())

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@id([eventId, personId])
  @@index([personId])
  @@index([eventId])
}

