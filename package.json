{
  "name": "aaee-ep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:db:reset": "dotenv -e .env.test -- prisma migrate reset --force --skip-seed",
    "test:db:migrate": "dotenv -e .env.test -- prisma migrate deploy",
    "test:dev": "dotenv -e .env.test -- next dev --port 3001",
    "test:e2e": "dotenv -e .env.test -- playwright test",
    "test:e2e:ui": "dotenv -e .env.test -- playwright test --ui",
    "test:e2e:headed": "dotenv -e .env.test -- playwright test --headed"
  },
  "dependencies": {
