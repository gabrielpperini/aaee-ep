# Ambiente de testes E2E. Carregado via `dotenv-cli -e .env.test` nos scripts.
# Não usar Supabase real — todo auth é mocado via shim em src/lib/supabase/*.

E2E_TEST_MODE=true
NEXT_PUBLIC_E2E_TEST_MODE=true

# Postgres local (docker-compose.test.yml na porta 5433).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/aaee_ep_test
DIRECT_URL=postgresql://postgres:postgres@localhost:5433/aaee_ep_test

# Supabase env precisa estar setado pra o build não quebrar, mas os valores
# são ignorados pelo shim quando E2E_TEST_MODE=true.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_test_publishable_key
SUPABASE_SERVICE_ROLE_KEY=sb_test_service_role_key

# Tempo congelado pra disponibilidade/dashboard/agenda serem determinísticos.
# Meio do "day1" do seed.
E2E_FROZEN_TIME=2026-05-22T15:00:00.000Z

# Web Push — valores dummy só pra o build não quebrar nos testes.
# Push real não é exercido em E2E (SW não roda em dev/test).
VAPID_PUBLIC_KEY=BEYtggNbzh8KMJD6tsuCDmzLbzfkNRKWIO38rnqqFSFji_e5FSK9WMqoBTCynDS7Km0nB6-lMRanWjajzHunhRs
VAPID_PRIVATE_KEY=nmNXDjczC3GiQMpGVcnK6QzoI1jIsLvGn-0HDFKawqs
VAPID_SUBJECT=mailto:test@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BEYtggNbzh8KMJD6tsuCDmzLbzfkNRKWIO38rnqqFSFji_e5FSK9WMqoBTCynDS7Km0nB6-lMRanWjajzHunhRs
CRON_SECRET=test-cron-secret
