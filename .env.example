# =======================
# Supabase
# =======================
# Encontre em: Project Settings -> API Keys
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Compatibilidade — Supabase renomeou ANON_KEY -> PUBLISHABLE_KEY.
# Os clients aceitam os dois nomes; deixe vazio se já usou PUBLISHABLE_KEY acima.
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Chave service_role — apenas server-side, NUNCA exposta ao cliente.
# Project Settings -> API Keys -> service_role secret
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# =======================
# Prisma / Postgres (Supabase)
# =======================
# Encontre em: Project Settings -> Database -> Connect
# Transaction pooler (porta 6543) — usar em runtime (Next.js).
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexão direta (porta 5432) — usada apenas pelo Prisma Migrate.
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# =======================
# Web Push (MVP 3 / Bloco B)
# =======================
# Gere o par com: npx web-push generate-vapid-keys
# A chave pública precisa estar em VAPID_PUBLIC_KEY e em NEXT_PUBLIC_VAPID_PUBLIC_KEY (mesma string).
VAPID_PUBLIC_KEY="BEx...sua-chave-publica"
VAPID_PRIVATE_KEY="sua-chave-privada-SECRETA"
VAPID_SUBJECT="mailto:contato@sua-aaee.com.br"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BEx...sua-chave-publica"

# Token aleatório que protege a route de cron. Gere com:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET="token-secreto-do-cron"

# =======================
# WhatsApp (microserviço baileys — ver whatsapp-service/)
# =======================
# Toda notificação push é enviada TAMBÉM por WhatsApp (sempre, ignora opt-out).
# O envio é delegado ao microserviço always-on (baileys) via HTTP — o app na
# Vercel não roda baileys. Sem estas vars o envio vira no-op silencioso
# (push continua funcionando).
# WHATSAPP_SERVICE_URL: base do serviço (ex: https://wa.suaaaee.com.br)
# WHATSAPP_SERVICE_TOKEN: mesmo valor do WA_SERVICE_TOKEN do serviço.
WHATSAPP_SERVICE_URL="https://wa.sua-aaee.com.br"
WHATSAPP_SERVICE_TOKEN="token-secreto-do-servico"
