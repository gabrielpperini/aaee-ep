# =======================
# Supabase
# =======================
# Encontre em: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Chave service_role — apenas server-side, NUNCA exposta ao cliente.
# Project Settings -> API -> service_role secret
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# =======================
# Prisma / Postgres (Supabase)
# =======================
# Connection pooler (porta 6543) — usar em runtime (Next.js).
# Em "Connect" no Supabase, copie a opção "Transaction" do pooler.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexão direta (porta 5432) — usada apenas pelo Prisma Migrate.
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
