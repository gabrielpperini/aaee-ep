# Porta do HTTP
PORT=9173

# Token compartilhado com o app (header Authorization: Bearer <token>).
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
WA_SERVICE_TOKEN=troque-por-um-token-secreto

# Diretório PERSISTENTE da sessão do WhatsApp. Local: ./auth_info.
# Em produção use um volume montado (ex: /data/auth) pra não reparear no restart.
WA_AUTH_DIR=./auth_info

# Opcional: nível de log (debug|info|warn|error)
LOG_LEVEL=info
